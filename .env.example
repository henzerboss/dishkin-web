# CloudPanel Node.js application port. Match the value in CloudPanel settings.
PORT=3000

# Public canonical URL
NEXT_PUBLIC_SITE_URL=https://dishkin.com
NEXT_PUBLIC_APP_STORE_URL=https://apps.apple.com/app/id6784972752
NEXT_PUBLIC_GOOGLE_PLAY_URL=https://play.google.com/store/apps/details?id=store.evsi.recipesgenerator
NEXT_PUBLIC_SUPPORT_EMAIL=support@evsi.store

# SQLite DB stored inside ./data. Create ./data before migrate.
DATABASE_URL="file:./data/dishkin.db"

# Admin login for /admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
AUTH_SECRET=generate-a-long-random-secret-with-openssl-rand-base64-32
AUTH_TRUST_HOST=true

# Server-to-server sync from evsi.store -> dishkin.com. Never put this token in the mobile app.
DISHKIN_SYNC_TOKEN=generate-another-long-random-token

# Optional analytics id, e.g. G-XXXXXXXXXX. Leave empty to disable.
NEXT_PUBLIC_GA_ID=
